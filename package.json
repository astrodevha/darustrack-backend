{
  "name": "darus-track-api",
  "version": "1.0.0",
  "description": "REST API backend untuk aplikasi Darustrack — sistem manajemen akademik pesantren.",
  "main": "app.js",
  "scripts": {
    "start": "NODE_ENV=production node ./bin/www",
    "dev": "nodemon ./bin/www",
    "seed": "sequelize db:seed:all",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^5.5.1",
    "fastest-validator": "^1.19.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "~1.9.1",
    "nanoid": "^3.3.11",
    "rate-limit-redis": "^1.7.0",
    "redis": "^5.5.6",
    "sequelize": "^6.37.6",
    "sequelize-cli": "^6.6.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mysql2": "^3.14.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.0"
  }
}